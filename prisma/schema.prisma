// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// This is the actual table that will be created in your Postgres DB
model Pledge {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  amount    Int
  createdAt DateTime @default(now())
}